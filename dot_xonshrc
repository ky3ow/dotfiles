import os
import sys

_xonsh_home = str(p"~/.config/xonsh")
try:
    if _xonsh_home not in $PYTHONPATH:
        $PYTHONPATH.append(_xonsh_home)
        sys.path.insert(0, _xonsh_home)
except KeyError: # no $PYTHONPATH defined
    $PYTHONPATH = ('', _xonsh_home)
    sys.path.insert(0, _xonsh_home)

def _configure():
    from xsh.helpers import Xontrib
    import xsh.aliases as alias

    $XONSH_VENV = os.path.dirname(os.path.dirname(sys.executable))
    $VIRTUAL_ENV = $XONSH_VENV

    @alias.function("xpip")
    @alias.ret_cmd
    def _xpip_uv(args):
        return {"cmd": ["uv", "pip"] + args, "env": {"VIRTUAL_ENV": $XONSH_VENV}}

    _module_ensures = [
        Xontrib("coreutils"),
        Xontrib("argcomplete"),
        Xontrib("abbreviations"),
        Xontrib("pipeliner"),
    ]

    for _module in _module_ensures:
        _module.ensure()

    _CONFIG_DIR = p"~/.config/xonsh"

    source @(_CONFIG_DIR / "profile.xsh")
    source @(_CONFIG_DIR / "main.xsh")

_configure()
