import os
import sys

# https://github.com/jnoortheen/xonsh-rd-parser - rust parser, faster but broken
# https://github.com/xonsh/xonsh/releases/tag/nightly-build - nightly release has compiled version with nuitka
# https://github.com/xxh/xxh - run on ssh

_xonsh_home = str(p"~/.config/xonsh")
try:
    if _xonsh_home not in $PYTHONPATH:
        $PYTHONPATH.append(_xonsh_home)
        sys.path.insert(0, _xonsh_home)
except KeyError: # no $PYTHONPATH defined
    $PYTHONPATH = ('', _xonsh_home)
    sys.path.insert(0, _xonsh_home)

def _configure():
    from xsh.helpers import Xontrib
    import xsh.aliases as alias

    from xonsh.prompt.base import PromptField

    @PromptField.wrap(prefix="{BOLD_YELLOW}", suffix="{RESET}")
    def up_to_date(fld, ctx):
       info = $PROMPT_FIELDS['gitstatus.porcelain'].value
       if info and info['ahead'] == 0 and info['behind'] == 0:
           fld.value = "*"       # show the symbol (prefix)
       else:
           fld.value = None     # hide it


    $XONSH_VENV = os.path.dirname(os.path.dirname(sys.executable))
    $VIRTUAL_ENV = $XONSH_VENV

    $XONSH_AUTOPAIR = True

    $PROMPT = (
        " {BOLD_YELLOW}{user}{RESET}"
        " in {BOLD_CYAN}{cwd_base}{branch_color}{gitstatus: {}}"
        " {RED}{last_return_code_if_nonzero:[{BOLD_INTENSE_RED}{}{RED}] }{RESET}"
          "{YELLOW}{env_name}{RESET}\n"
          "{BOLD_GREEN}{prompt_end}{RESET} ")

    $PROMPT_FIELDS["gitstatus.up_to_date"] = up_to_date

    $PROMPT_FIELDS["gitstatus"].fragments = (
        ".branch",
        ".short_head",
        "{BOLD_GREEN}(",
        ".up_to_date",
        ".ahead",
        ".behind",
        "{BOLD_GREEN}){RESET}",
        ".staged",
        ".changed",
        ".conflicts",
        ".deleted",
        ".untracked",
        ".stash_count",
    )
    $PROMPT_FIELDS['gitstatus.branch'].prefix = "{BOLD_YELLOW}"
    $PROMPT_FIELDS['gitstatus.short_head'].prefix = "{BOLD_GREEN}@"
    $PROMPT_FIELDS['gitstatus.ahead'].prefix = "{BOLD_BLUE}"
    $PROMPT_FIELDS['gitstatus.behind'].prefix = ":{BOLD_PURPLE}"

    $PROMPT_FIELDS["gitstatus.staged"].prefix = " {BOLD_GREEN}*"
    $PROMPT_FIELDS["gitstatus.changed"].prefix = " {BOLD_BLUE}~"
    $PROMPT_FIELDS["gitstatus.conflicts"].prefix = " {BOLD_RED}="
    $PROMPT_FIELDS["gitstatus.deleted"].prefix = " {BOLD_RED}-"
    $PROMPT_FIELDS["gitstatus.untracked"].prefix = " {BOLD_RED}?"
    $PROMPT_FIELDS["gitstatus.stash_count"].prefix = " {BOLD_PURPLE}$"

    @alias.function("xpip")
    @alias.ret_cmd
    def _xpip_uv(args):
        return {"cmd": ["uv", "pip"] + args, "env": {"VIRTUAL_ENV": $XONSH_VENV}}

    _module_ensures = [
        Xontrib("coreutils"),
        Xontrib("argcomplete"),
        Xontrib("abbreviations"),
        Xontrib("pipeliner"),
    ]

    for _module in _module_ensures:
        _module.ensure()

    _CONFIG_DIR = p"~/.config/xonsh"

    source @(_CONFIG_DIR / "profile.xsh")
    source @(_CONFIG_DIR / "main.xsh")

_configure()
